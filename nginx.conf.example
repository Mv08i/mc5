server {
    listen 80;
    server_name your-domain.com;

    root /var/www/your-domain/dist;
    index index.html;

    # 静态文件直接返回
    location ~* \.(js|css|svg|png|jpg|ico)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # SPA fallback - 所有路由都指向 index.html
    location / {
        try_files $uri $uri/ /index.html;
    }
}
